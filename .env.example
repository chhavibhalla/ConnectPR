# connectPR — environment variables
# Copy this file to ".env" and fill in your Supabase project values.
# The .env file is gitignored (never committed).
#
# Where to find these: Supabase dashboard -> Project Settings -> API
# Full walkthrough: see SETUP_SUPABASE.md
#
# Leaving these blank is fine — the app runs in local mode (localStorage,
# no login) until you add real values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
